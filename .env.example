DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Stripe (test mode) — klucze z https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Publishable key — używany w przeglądarce, więc MUSI mieć prefiks NEXT_PUBLIC_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Sekret webhooka — dodamy w pod-kroku 6d/6f (Stripe CLI)
STRIPE_WEBHOOK_SECRET=whsec_...
